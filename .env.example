# Active profile
SPRING_PROFILES_ACTIVE=dev

# DB
# Local example: docker-compose-local.yml
DATASOURCE_URL=jdbc:mysql://localhost:23214/yeahpeu?useUnicode=true&characterEncoding=UTF-8&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul
DATASOURCE_USERNAME=user
DATASOURCE_PASSWORD=password

# JWT
# Generate a sufficiently long Base64 secret for real environments.
APPLICATION_SECURITY_JWT_SECRET_KEY=replace-with-base64-secret
APPLICATION_SECURITY_JWT_ACCESS_TOKEN_EXPIRATION=3600000
APPLICATION_SECURITY_JWT_REFRESH_TOKEN_EXPIRATION=86400000

# Google OAuth2
SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_ID=replace-with-google-client-id
SECURITY_OAUTH2_CLIENT_REGISTRATION_GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# OpenAI
AI_OPENAI_API_KEY=replace-with-openai-api-key

# Naver API
API_NAVER_CLIENT_ID=replace-with-naver-client-id
API_NAVER_CLIENT_SECRET=replace-with-naver-client-secret

# AWS S3
AWS_BUCKET_NAME=replace-with-bucket-name
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY=replace-with-access-key
AWS_SECRET_KEY=replace-with-secret-key

# CORS
APP_CORS_ALLOW_HOSTS_FRONT=http://localhost:3000
APP_CORS_ALLOW_HOSTS_LOCAL=http://localhost:8082

# Mail
GOOGLE_MAIL_USERNAME=replace-with-mail-username
GOOGLE_MAIL_PASSWORD=replace-with-mail-password
